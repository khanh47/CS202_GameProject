{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake Configure",
      "type": "shell",
      "command": "${env:ProgramFiles}/CMake/bin/cmake.exe",
      "args": [
        "-S",
        ".",
        "-B",
        "build",
        "-G",
        "MinGW Makefiles"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CMake Build",
      "type": "shell",
      "command": "${env:ProgramFiles}/CMake/bin/cmake.exe",
      "args": [
        "--build",
        "build",
        "-j"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "CMake Configure",
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "CMake Run",
      "type": "shell",
      "command": "./build/run.exe",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "CMake Build",
      "problemMatcher": []
    }
  ]
}
